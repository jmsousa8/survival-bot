# Game to monitor (soulmask, valheim)
GAME=soulmask

# Path to the game server log file
# Soulmask Windows example:
# LOG_FILE_PATH=C:\Users\itsme\Soulmask Server\steamapps\common\Soulmask Dedicated Server For Windows\WS\Saved\Logs\WS.log
LOG_FILE_PATH=

# Discord Bot Token (required)
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Discord Guild (Server) ID (required)
# Enable Developer Mode in Discord, right-click server name > Copy ID
DISCORD_GUILD_ID=

# Discord Channel ID for sending event messages (required)
# Right-click channel name > Copy ID
DISCORD_CHANNEL_ID=

# Discord Owner User ID for debug commands (optional)
# Your Discord user ID - enables DMs to trigger debug output
# Right-click your username in Discord > Copy User ID
DISCORD_OWNER_ID=

# SQLite database path (required, defaults to ./bot.db)
DB_PATH=./bot.db

# Gemini API Key for AI-generated messages (optional)
# Free tier available at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
